  <!-- NAV -->
  <nav>
    <a href="#" class="nav-logo">store<span>craft</span></a>
    <a href="#contact" class="nav-cta">Get Your Store</a>
  </nav>

  <!-- HERO -->
  <section class="hero" id="home">
